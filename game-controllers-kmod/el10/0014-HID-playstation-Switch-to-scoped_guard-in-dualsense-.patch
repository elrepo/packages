-		input_sync(ds->jack);
-		ds->prev_plugged_state = ds->plugged_state;
-	}
-
-	if (ds->update_mic_mute) {
-		common->valid_flag1 |= DS_OUTPUT_VALID_FLAG1_MIC_MUTE_LED_CONTROL_ENABLE;
-		common->mute_button_led = ds->mic_muted;
+			if (ds->mic_muted) {
