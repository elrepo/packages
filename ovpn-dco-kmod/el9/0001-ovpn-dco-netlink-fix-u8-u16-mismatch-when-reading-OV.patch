From fd3dac4b07933d39e0b2c2fc7e2f4fb8ae79532c Mon Sep 17 00:00:00 2001
From: Arne Schwabe <arne@openvpn.net>
Date: Mon, 16 Feb 2026 21:16:20 +0100
Subject: [PATCH 1/6] ovpn-dco: netlink - fix u8/u16 mismatch when reading
 OVPN_NEW_KEY_ATTR_KEY_ID on BigEndian

This mismatch causes IDs > 0 to be parsed incorrectly on big-endian
platforms (tested on s390x qemu emulator), thus failing the key
installation.

Github: closes OpenVPN/ovpn-dco#95
Suggested-by: Ralf Lici <ralf@mandelbit.com>
Signed-off-by: Arne Schwabe <arne@openvpn.net>
---
 drivers/net/ovpn-dco/netlink.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/ovpn-dco/netlink.c b/drivers/net/ovpn-dco/netlink.c
index 8e5729d..46b4b3d 100644
--- a/drivers/net/ovpn-dco/netlink.c
+++ b/drivers/net/ovpn-dco/netlink.c
@@ -237,7 +237,7 @@ static int ovpn_netlink_new_key(struct sk_buff *skb, struct genl_info *info)
 
 	peer_id = nla_get_u32(attrs[OVPN_NEW_KEY_ATTR_PEER_ID]);
 	pkr.slot = nla_get_u8(attrs[OVPN_NEW_KEY_ATTR_KEY_SLOT]);
-	pkr.key.key_id = nla_get_u16(attrs[OVPN_NEW_KEY_ATTR_KEY_ID]);
+	pkr.key.key_id = nla_get_u8(attrs[OVPN_NEW_KEY_ATTR_KEY_ID]);
 
 	pkr.key.cipher_alg = nla_get_u16(attrs[OVPN_NEW_KEY_ATTR_CIPHER_ALG]);
 
-- 
